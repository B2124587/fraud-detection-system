# ─── Database (MySQL only) ───────────────────────────────────────
# Point this at your local MySQL Server (e.g. installed via the MySQL
# Installer for Windows, or MySQL Workbench's bundled server).
# Create the database first with:
#   mysql -u root -p < migrations/001_initial_schema.sql
DATABASE_URL=mysql+pymysql://root:YOUR_MYSQL_PASSWORD@localhost:3306/zambia_fraud

# ─── JWT ────────────────────────────────────────────────────────
SECRET_KEY=zambia-fraud-cbu-cs301-group20-change-this-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ─── App ────────────────────────────────────────────────────────
DEBUG=true
MODEL_PATH=./models

# ─── Retraining ─────────────────────────────────────────────────
MIN_SAMPLES_FOR_RETRAIN=500
